{
  "expo": {
    "name": "CityFlow",
    "slug": "cityflow",
    "scheme": "cityflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#08011A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cityflow.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "NSLocationWhenInUseUsageDescription": "CityFlow uses your location to show nearby services and rides.",
        "NSCameraUsageDescription": "CityFlow uses your camera for profile photos and lost & found reports.",
        "NSPhotoLibraryUsageDescription": "CityFlow accesses your photos for profile and report uploads."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#08011A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.cityflow.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08011A",
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C48D38",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "experiments": {
      "newArchEnabled": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
